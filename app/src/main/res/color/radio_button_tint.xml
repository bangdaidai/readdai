<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 未选中状态：使用主题适配的颜色 -->
    <item android:color="@color/ate_control_normal"/>
    <!-- 禁用状态 -->
    <item android:alpha="0.38" android:color="@color/disabled" android:state_enabled="false"/>
    <!-- 选中状态 -->
    <item android:alpha="1.0" android:color="?attr/colorAccent" android:state_checked="true"/>
</selector>
