<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_discover_title_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="0dp"
    android:paddingEnd="8dp"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:id="@+id/ll_discover_source_select"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/bookshelf_title_select_height"
        android:background="@drawable/bg_discover_embedded_action"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="0dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tv_discover_source_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/primaryText"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_discover_source_arrow"
            android:layout_width="@dimen/bookshelf_title_arrow_size"
            android:layout_height="@dimen/bookshelf_title_arrow_size"
            android:contentDescription="@string/discovery"
            android:src="@drawable/ic_arrow_drop_down"
            app:tint="@color/primaryText" />

    </LinearLayout>

    <Space
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_discover_source_search"
        android:layout_width="@dimen/bookshelf_action_button_size"
        android:layout_height="@dimen/bookshelf_action_button_size"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/search"
        android:padding="@dimen/bookshelf_action_button_padding"
        android:scaleType="centerInside"
        android:src="@drawable/ic_search"
        android:tint="@color/primaryText"
        android:visibility="gone" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_discover_tag_filter"
        android:layout_width="@dimen/bookshelf_action_button_size"
        android:layout_height="@dimen/bookshelf_action_button_size"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/sort"
        android:padding="@dimen/bookshelf_action_button_padding"
        android:scaleType="centerInside"
        android:src="@drawable/ic_sort"
        android:tint="@color/primaryText" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_discover_source_login"
        android:layout_width="@dimen/bookshelf_action_button_size"
        android:layout_height="@dimen/bookshelf_action_button_size"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/login"
        android:padding="@dimen/bookshelf_action_button_padding"
        android:scaleType="centerInside"
        android:src="@drawable/ic_bottom_person"
        android:tint="@color/primaryText" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_discover_mode_toggle"
        android:layout_width="@dimen/bookshelf_action_button_size"
        android:layout_height="@dimen/bookshelf_action_button_size"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/modern_discovery_page"
        android:padding="@dimen/bookshelf_action_button_padding"
        android:scaleType="centerInside"
        android:src="@drawable/ic_view_list"
        android:tint="@color/primaryText" />

</LinearLayout>
