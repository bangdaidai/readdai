<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/backgroundCard"
    app:cardElevation="0dp"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- 左侧内容 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <io.legado.app.ui.widget.text.PrimaryTextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="累计阅读成就" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="bottom">

                <io.legado.app.ui.widget.text.SecondaryTextView
                    android:id="@+id/tv_book_count_prefix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:text="已读"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="1dp" />

                <io.legado.app.ui.widget.text.PrimaryTextView
                    android:id="@+id/tv_book_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:text="0"
                    android:layout_marginLeft="4dp"
                    android:layout_gravity="bottom" />

                <io.legado.app.ui.widget.text.SecondaryTextView
                    android:id="@+id/tv_book_count_suffix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:text="本书"
                    android:layout_marginLeft="2dp"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="1dp" />

            </LinearLayout>

            <io.legado.app.ui.widget.text.SecondaryTextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:text="共阅读 0 分钟" />

        </LinearLayout>



    </LinearLayout>



</com.google.android.material.card.MaterialCardView>
