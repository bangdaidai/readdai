<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:title="@string/add_tag" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <io.legado.app.ui.widget.text.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:hint="@string/input_tag_name"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            app:boxCollapsedPaddingTop="0dp">

            <io.legado.app.lib.theme.view.ThemeEditText
                android:id="@+id/edit_tag"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:maxLines="1"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="0dp"
                android:paddingBottom="2dp"
                android:gravity="bottom"
                android:includeFontPadding="false"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:textSize="14sp" />
        </io.legado.app.ui.widget.text.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <io.legado.app.ui.widget.text.AccentBgTextView
                android:id="@+id/tag_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="标签预览"
                android:textSize="12sp"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                app:radius="12dp" />

            <io.legado.app.ui.widget.text.SecondaryTextView
                android:id="@+id/color_hex_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="#E3F2FD"
                android:textSize="14sp" />

            <io.legado.app.ui.widget.text.AccentTextView
                android:id="@+id/btn_select_color"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/select_color"
                android:textSize="14sp" />

        </LinearLayout>

        <io.legado.app.ui.widget.text.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="选择分组"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            app:boxCollapsedPaddingTop="0dp">

            <io.legado.app.ui.widget.text.AutoCompleteTextView
                android:id="@+id/edit_group"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:maxLines="1"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="0dp"
                android:paddingBottom="2dp"
                android:gravity="bottom"
                android:includeFontPadding="false"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:textSize="14sp"
                android:dropDownVerticalOffset="6dp" />
        </io.legado.app.ui.widget.text.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:orientation="horizontal">

            <io.legado.app.ui.widget.text.AccentTextView
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="10dp"
                android:paddingBottom="8dp"
                android:text="@string/delete"
                android:textColor="@color/red"
                android:textSize="14sp" />

            <io.legado.app.ui.widget.text.AccentTextView
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/cancel"
                android:textSize="14sp" />

            <io.legado.app.ui.widget.text.AccentTextView
                android:id="@+id/btn_confirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="@string/confirm"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>