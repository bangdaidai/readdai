<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="0dp"
    android:layout_marginEnd="0dp"
    android:layout_marginTop="0dp"
    android:minHeight="0dp">

    <!-- 排名 -->
    <TextView
            android:id="@+id/tvRank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/secondaryText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <!-- 书名 -->
    <TextView
        android:id="@+id/tvBookName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="3dp"
        android:text="示例书籍名称"
        android:textColor="@color/secondaryText"
        android:textSize="14sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:contentDescription="@string/book_name"
        app:layout_constraintBaseline_toBaselineOf="@id/tvRank"
        app:layout_constraintStart_toEndOf="@id/tvRank"
        app:layout_constraintEnd_toStartOf="@id/tvReadTime" />

    <!-- 阅读时间 -->
    <TextView
            android:id="@+id/tvReadTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="120分钟"
            android:textColor="@color/secondaryText"
            android:textSize="14sp"
            android:contentDescription="@string/read_time"
            app:layout_constraintBaseline_toBaselineOf="@id/tvRank"
            app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>