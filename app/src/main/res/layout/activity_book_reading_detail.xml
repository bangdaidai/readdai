<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 使用TitleBar组件 -->
    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:title="@string/book_reading_detail" />

    <!-- 下拉刷新 -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/title_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 内容布局 -->
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fadingEdge="none"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:fillViewport="true"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:id="@+id/contentLayout"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:paddingVertical="16dp">

                <!-- 书籍基本信息区域 -->
                <androidx.cardview.widget.CardView
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:orientation="vertical"
                        android:padding="16.0dip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                    
                    <io.legado.app.ui.widget.image.CoverImageView
                        android:id="@+id/iv_cover"
                        android:layout_width="90.0dip"
                        android:layout_height="120.0dip"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/img_cover"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                        
                    <io.legado.app.ui.widget.text.PrimaryTextView
                        android:id="@+id/tv_book_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Legado.BodyLarge"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/iv_cover"
                        android:layout_marginEnd="16dp" />
                        
                    <io.legado.app.ui.widget.text.SummaryTextView
                        android:id="@+id/tv_author"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                        app:layout_constraintTop_toBottomOf="@id/tv_book_name"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/iv_cover"
                        android:layout_marginEnd="16dp" />
                        
                    <!-- 阅读状态和评分行 -->
                    <LinearLayout
                        android:id="@+id/linearLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/tv_author"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/iv_cover"
                        android:layout_marginEnd="16dp">
                        
                        <!-- 阅读状态 -->
                        <io.legado.app.ui.widget.text.AccentTextView
                            android:id="@+id/tv_reading_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="待读"
                            android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                            android:paddingStart="0dp"
                            android:paddingEnd="6dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="start" />
                        
                        <!-- 评分 -->
                        <io.legado.app.ui.widget.RatingView
                            android:id="@+id/ratingView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:starCount="5"
                            app:starSize="20dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:useYellowStars="true" />
                    </LinearLayout>
                        
                    <io.legado.app.ui.widget.text.SummaryTextView
                        android:id="@+id/tv_word_count"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        tools:text="字数  100000"
                        android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/iv_cover"
                        android:layout_marginEnd="16dp" />
                        
                    <io.legado.app.lib.theme.view.ThemeProgressBar
                        android:id="@+id/pb_reading_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="0dp"
                        android:layout_marginEnd="16dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="?android:attr/textColorSecondary"
                        android:progressTint="@color/accent"
                        app:layout_constraintTop_toBottomOf="@id/tv_word_count"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/iv_cover"
                        android:gravity="start" />
                        
                        <!-- 读完时间 -->
                            <io.legado.app.ui.widget.text.SummaryTextView
                                android:id="@+id/tv_finish_read_time"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="12sp"
                                app:layout_constraintTop_toBottomOf="@id/pb_reading_progress"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toStartOf="@id/iv_cover"
                                android:layout_marginEnd="16dp"
                                android:visibility="gone" />
                        
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <!-- 主角名区域 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/protagonist_card"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                    
                        <!-- 主角标题和添加按钮 -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <io.legado.app.ui.widget.text.PrimaryTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="主角"
                            android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                            android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/ivAddProtagonist"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_add"
                                android:background="?android:attr/selectableItemBackgroundBorderless"
                                android:contentDescription="添加主角"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                        
                        <!-- 主角名标签容器 -->
                        <LinearLayout
                            android:id="@+id/protagonist_container"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="start" 
                            android:layout_marginTop="8dp" />
                    
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 书籍介绍区域 -->
                <androidx.cardview.widget.CardView
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                    <io.legado.app.ui.widget.text.PrimaryTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_intro"
                        android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                        android:textStyle="bold" />
                    
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">
                        <io.legado.app.ui.widget.text.SummaryTextView
                            android:id="@+id/tv_intro"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                            android:maxLines="5"
                            android:clickable="true"
                            android:focusable="true" />
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:layout_marginTop="8dp">
                            <io.legado.app.ui.widget.text.AccentTextView
                                android:id="@+id/tv_expand_collapse"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="展开更多"
                                android:textSize="12sp"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>
                    </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 标签区域 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/llTags"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                    
                    <!-- 标签标题和添加按钮 -->
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        
                        <io.legado.app.ui.widget.text.PrimaryTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/book_tags"
                            android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                            android:textStyle="bold" />
                        
                        <ImageView
                            android:id="@+id/ivAddTag"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_add"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/add_tag"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                    
                    <!-- 标签容器 -->
                    <io.legado.app.ui.widget.BookTagsView
                        android:id="@+id/bookTagsView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                    
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 阅读数据区域 -->
                <androidx.cardview.widget.CardView
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                    <io.legado.app.ui.widget.text.PrimaryTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/reading_data"
                        android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                        android:textStyle="bold" />
                    
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp">
                        
                        <!-- 第一行：两列布局 -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            
                            <!-- 左侧：累计时长 -->
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginRight="8dp">
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_total_reading_time"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="累计时长"
                                    android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                                    android:textStyle="bold" />
                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="start|bottom">
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_total_reading_hours"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="2"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_hours_unit"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="小时"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="1dp"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_total_reading_minutes"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="30"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_marginLeft="4dp"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_minutes_unit"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="分钟"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="1dp"
                                        android:layout_gravity="bottom" />
                                </LinearLayout>
                                
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_start_reading_time"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    tools:text="2025年12月21日开始阅读"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                            
                            <!-- 右侧：阅读天数 -->
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="8dp">
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_reading_days"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="阅读天数"
                                    android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                                    android:textStyle="bold" />
                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="bottom">
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_reading_days_value"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="5"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="天"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="1dp"
                                        android:layout_gravity="bottom" />
                                </LinearLayout>
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_last_reading_time"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    tools:text="上次阅读今天"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                        
                        <!-- 第二行：两列布局 -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp">
                            
                            <!-- 左侧：总阅读进度 -->
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginRight="8dp">
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_reading_progress"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="总阅读进度"
                                    android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                                    android:textStyle="bold" />
                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="bottom">
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_reading_progress_value"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="30"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="%"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="0dp"
                                        android:layout_gravity="bottom" />
                                </LinearLayout>
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_read_chapters"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    tools:text="已读章节: 6/20"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                            
                            <!-- 右侧：想法条数 -->
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="8dp">
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_review_count"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="想法笔记"
                                    android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                                    android:textStyle="bold" />
                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="bottom">
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_review_count_value"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="3"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="条"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="1dp"
                                        android:layout_gravity="bottom" />
                                </LinearLayout>
                                <io.legado.app.ui.widget.text.SummaryTextView
                    android:id="@+id/tv_annotation_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    tools:text="5条书摘" />
                            </LinearLayout>
                        </LinearLayout>
                        
                        <!-- 第三行：两列布局 -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp">
                            
                            <!-- 左侧：单日阅读最久 -->
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginRight="8dp">
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_max_day_read_time"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="单日阅读最久"
                                    android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                                    android:textStyle="bold" />
                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="start|bottom">
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_max_day_read_hours"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="3"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_max_hours_unit"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="小时"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="1dp"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_max_day_read_minutes"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="45"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_marginLeft="4dp"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_max_minutes_unit"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="分钟"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="1dp"
                                        android:layout_gravity="bottom" />
                                </LinearLayout>
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_max_day_read_date"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    tools:text="20251225"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                            
                            <!-- 右侧：阅读总字数 -->
                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginLeft="8dp">
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_total_read_words"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="阅读总字数"
                                    android:textAppearance="@style/TextAppearance.Legado.BodyExtraSmall"
                                    android:textStyle="bold" />
                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="start|bottom">
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:id="@+id/tv_total_read_words_value"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="100000"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:layout_gravity="bottom" />
                                    <io.legado.app.ui.widget.text.PrimaryTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="万字"
                                        android:textSize="16sp"
                                        android:layout_marginLeft="2dp"
                                        android:layout_marginBottom="1dp"
                                        android:layout_gravity="bottom" />
                                </LinearLayout>
                                <io.legado.app.ui.widget.text.SummaryTextView
                                    android:id="@+id/tv_remaining_words"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    tools:text="剩余字数900000"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 书摘内容区域 -->
                <androidx.cardview.widget.CardView
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                    <io.legado.app.ui.widget.text.PrimaryTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/book_annotations"
                        android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                        android:textStyle="bold" />
                    
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_annotations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 书评区域 -->
                <androidx.cardview.widget.CardView
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                    <!-- 书评标题和添加按钮 -->
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <io.legado.app.ui.widget.text.PrimaryTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/book_reviews"
                            android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                            android:textStyle="bold" />
                        <ImageView
                            android:id="@+id/ivAddReview"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_add"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/add_review"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                    
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_reviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 阅读会话区域 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/reading_session_card"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/backgroundCard">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <io.legado.app.ui.widget.text.PrimaryTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="阅读会话"
                            android:textAppearance="@style/TextAppearance.Legado.BodySmall"
                            android:textStyle="bold" />
                        
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recycler_reading_sessions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- 导航栏背景 -->
    <View
        android:id="@+id/vw_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>