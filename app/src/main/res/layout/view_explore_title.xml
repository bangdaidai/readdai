<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_discover_source_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_searchview"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp">

    <LinearLayout
        android:id="@+id/ll_discover_source_select"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:background="@drawable/bg_searchview"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tv_discover_source_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/primaryText"
            android:textSize="14sp"
            tools:text="默认书源" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_discover_source_arrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/discovery"
            android:src="@drawable/ic_arrow_drop_down"
            app:tint="@color/primaryText" />

    </LinearLayout>

    <Space
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_discover_source_search"
        android:layout_width="36dp"
        android:layout_height="30dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_searchview"
        android:contentDescription="@string/search"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_search"
        android:tint="@color/primaryText"
        android:visibility="gone" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_discover_tag_filter"
        android:layout_width="36dp"
        android:layout_height="30dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_searchview"
        android:contentDescription="@string/sort"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_sort"
        android:tint="@color/primaryText" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btn_discover_source_login"
        android:layout_width="36dp"
        android:layout_height="30dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_searchview"
        android:contentDescription="@string/login"
        android:padding="4dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_bottom_person"
        android:tint="@color/primaryText" />

</LinearLayout>