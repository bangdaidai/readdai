<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="8dp">

    <!-- 月份标题栏 -->
    <LinearLayout
        android:id="@+id/month_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp"
        android:clickable="true"
        android:focusable="true">
        
        <io.legado.app.ui.widget.text.PrimaryTextView
            android:id="@+id/tv_month_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2025年12月"
            android:textSize="14sp"
            android:textStyle="bold" />
        
        <io.legado.app.ui.widget.text.SecondaryTextView
            android:id="@+id/tv_month_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="总时长: 10小时30分钟"
            android:textSize="12sp" />
        
        <ImageView
            android:id="@+id/iv_expand_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_expand_more"
            android:layout_marginLeft="8dp" />
    </LinearLayout>
    
    <!-- 每日阅读时间列表 -->
    <LinearLayout
        android:id="@+id/daily_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        
        <!-- 每日阅读时间项将通过代码动态添加 -->
        
    </LinearLayout>
    
</LinearLayout>