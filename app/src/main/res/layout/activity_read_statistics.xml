<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <io.legado.app.ui.widget.TitleBar
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- 使用 NestedScrollView 使整个页面可滚动，支持嵌套滚动 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarStyle="insideOverlay"
        android:overScrollMode="always">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 统计类型选择按钮组 -->
            <LinearLayout
                android:id="@+id/statisticsTypeContainer"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_reading_filter_container"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp">

                <!-- 总计按钮 -->
                <io.legado.app.ui.widget.text.PrimaryTextView
                    android:id="@+id/cardTotal"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="总计"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_reading_tab_selected"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- 每日按钮 -->
                <io.legado.app.ui.widget.text.PrimaryTextView
                    android:id="@+id/cardDaily"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="每日"
                    android:textSize="14sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_reading_tab_unselected"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- 每月按钮 -->
                <io.legado.app.ui.widget.text.PrimaryTextView
                    android:id="@+id/cardMonthly"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="每月"
                    android:textSize="14sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_reading_tab_unselected"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- 每年按钮 -->
                <io.legado.app.ui.widget.text.PrimaryTextView
                    android:id="@+id/cardYearly"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="每年"
                    android:textSize="14sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@drawable/bg_reading_tab_unselected"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- 时间导航卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/navigationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/card_margin"
                android:layout_marginEnd="@dimen/card_margin"
                android:layout_marginBottom="@dimen/card_margin"
                android:visibility="visible"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/backgroundCard">

                <LinearLayout
                    android:id="@+id/navigationContainer"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageButton
                        android:id="@+id/btnPrev"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/shape_white_circle"
                        android:src="@drawable/ic_chevron_left_16"
                        android:tint="@android:color/white"
                        android:contentDescription="@string/nav_previous_year"
                        android:scaleType="center"
                        android:layout_marginEnd="4dp" />

                    <io.legado.app.ui.widget.text.PrimaryTextView
                        android:id="@+id/tvCurrentPeriod"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="2025年"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnNext"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/shape_white_circle"
                        android:src="@drawable/ic_chevron_right_16"
                        android:tint="@android:color/white"
                        android:contentDescription="@string/nav_next_year"
                        android:scaleType="center"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 阅读总览卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/overviewCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/card_margin"
                android:layout_marginEnd="@dimen/card_margin"
                android:layout_marginBottom="@dimen/card_margin"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/backgroundCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- 阅读总览标题 -->
                    <io.legado.app.ui.widget.text.PrimaryTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="阅读总览"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- 阅读总览内容 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:scrollbars="none" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 热力图卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/heatmapCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/card_margin"
                android:layout_marginEnd="@dimen/card_margin"
                android:layout_marginBottom="@dimen/card_margin"
                android:visibility="gone"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/backgroundCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <!-- 热力图标题 -->
                    <io.legado.app.ui.widget.text.PrimaryTextView
                        android:id="@+id/tvHeatmapTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- 热力图容器 -->
                    <LinearLayout
                        android:id="@+id/heatmapContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- 月度热力图 -->
                        <io.legado.app.ui.widget.MonthlyHeatmapView
                            android:id="@+id/monthlyHeatmapView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                        <!-- 年度热力图 -->
                        <io.legado.app.ui.widget.YearlyHeatmapView
                            android:id="@+id/yearlyHeatmapView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- 阅读时长排行TOP10卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/top10Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/card_margin"
                android:layout_marginEnd="@dimen/card_margin"
                android:layout_marginBottom="@dimen/card_margin"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/backgroundCard">

                <androidx.compose.ui.platform.ComposeView
                    android:id="@+id/composeTop10Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>