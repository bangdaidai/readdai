<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_book_info_intro_panel"
    android:padding="12dp">

    <!-- Icon Preview -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_preview"
        android:layout_width="28dp"
        android:layout_height="28dp"
        app:cardCornerRadius="@dimen/ui_panel_radius"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <ImageView
            android:id="@+id/iv_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/background_image"
            android:scaleType="centerInside"
            android:padding="4dp" />

    </androidx.cardview.widget.CardView>

    <!-- Name -->
    <TextView
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="6dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/card_preview"
        app:layout_constraintBottom_toBottomOf="@id/card_preview"
        app:layout_constraintLeft_toRightOf="@id/card_preview"
        app:layout_constraintRight_toLeftOf="@id/btn_apply" />

    <!-- Apply Button -->
    <TextView
        android:id="@+id/btn_apply"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:minWidth="38dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:singleLine="true"
        android:text="@string/theme_apply"
        android:textSize="11sp"
        android:textColor="?attr/colorAccent"
        app:layout_constraintTop_toTopOf="@id/card_preview"
        app:layout_constraintBottom_toBottomOf="@id/card_preview"
        app:layout_constraintRight_toLeftOf="@id/btn_edit" />

    <!-- Edit Button -->
    <TextView
        android:id="@+id/btn_edit"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:minWidth="38dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:singleLine="true"
        android:text="@string/edit"
        android:textSize="11sp"
        android:textColor="?attr/colorAccent"
        app:layout_constraintTop_toTopOf="@id/card_preview"
        app:layout_constraintBottom_toBottomOf="@id/card_preview"
        app:layout_constraintRight_toLeftOf="@id/btn_delete" />

    <!-- Delete Button -->
    <TextView
        android:id="@+id/btn_delete"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:layout_marginStart="4dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center"
        android:minWidth="38dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:singleLine="true"
        android:text="@string/delete"
        android:textSize="11sp"
        android:textColor="@android:color/holo_red_dark"
        app:layout_constraintTop_toTopOf="@id/card_preview"
        app:layout_constraintBottom_toBottomOf="@id/card_preview"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
